# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/clearhire?appName=Cluster0

# Groq API Key (for Llama 3.1 70B scoring)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# WhatsApp Cloud API (Meta Developer Portal)
# Get it from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WA_TOKEN=your_whatsapp_bearer_token
WA_PHONE_NUMBER_ID=your_phone_number_id

# WhatsApp Webhook Verification Token (any random string you choose)
WA_VERIFY_TOKEN=clearhire_verify_2026

# Server port (Cloud Run uses 8080)
PORT=8080

# Node environment
NODE_ENV=development
